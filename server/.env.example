PORT=4000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/company-portal?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=7d

# Cloudflare R2 (S3 호환)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=company-portal
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# 가비아 하이웍스 메일
HIWORKS_API_URL=https://api.hiworks.com
HIWORKS_API_KEY=your-hiworks-api-key
HIWORKS_MAIL_FROM=noreply@yourcompany.com

# IP 화이트리스트 (콤마 구분, 직원 접속 허용 IP)
ALLOWED_IPS=127.0.0.1,::1

# CORS 허용 출처
CLIENT_URL=http://localhost:3000
